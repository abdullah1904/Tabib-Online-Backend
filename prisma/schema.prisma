generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                         String             @id @default(uuid())
  fullName                   String
  age                        Int
  gender                     Int
  email                      String
  address                    String
  phoneNumber                String
  verificationDocumentType   Int
  verificationDocumentNumber String
  verificationDocumentURL    String
  password                   String
  role                       Int
  suspendedTill              DateTime?
  status                     Int                @default(0)
  balance                    Float              @default(0)
  imageURL                   String             @default("")
  verifiedAt                 DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  medicalInfo                MedicalRecords?
  professionalInfo           ProfessionalInfos?
  verifications              Verifications[]
  doctorReviews              Reviews[]          @relation("DoctorReviews")
  userReviews                Reviews[]          @relation("UserReviews")
  consultations              Consultations[]
  doctorAppointments         Appointments[]     @relation("DoctorAppointments")
  patientAppointments        Appointments[]     @relation("UserAppointments")

  @@unique([email, verificationDocumentNumber, verificationDocumentType, phoneNumber])
}

model Verifications {
  otp       String   @id
  userId    String
  type      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedicalRecords {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  emergencyContactName   String
  emergencyContactNumber String
  bloodType              String
  height                 Float
  weight                 Float
  allergies              String
  currentMedications     String
  familyMedicalHistory   String
  pastMedicalHistory     String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfessionalInfos {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  prefix                     Int                @default(1)
  medicalDegree          Int
  postGraduateDegree     Int
  specialization         Int
  yearsOfExperience      Int
  PMDCRedgNo             String
  PMDCRedgDate           DateTime
  PMDCLicenseDocumentURL String
  PMDCVerifiedAt         DateTime?
  isActive                Boolean   @default(false)
  isPMDCEditable         Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reviews {
  id        String   @id @default(uuid())
  doctorId  String
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Users    @relation("DoctorReviews", fields: [doctorId], references: [id], onDelete: Cascade)
  user      Users    @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
}

model Consultations {
  id                    String                  @id @default(uuid())
  title                 String
  type                  Int
  price                 Int
  duration              Int
  time                  DateTime
  location              String?
  allowCustom           Boolean                 @default(false)
  doctorId              String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  doctor                Users                   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  consultationSlots     ConsultationSlots[]
  appointments          Appointments[]
}

model ConsultationSlots {
  id        String   @id @default(uuid())
  serviceId String
  dayOfWeek Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Consultations @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Appointments {
  id                       String   @id @default(uuid())
  userId                   String
  doctorId                 String
  consultationId           String
  appointmentDate          DateTime
  appointmentTime          DateTime
  additionalNotes          String?
  healthInfoSharingConsent Boolean  @default(false)
  status                   Int
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  doctor                   Users    @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patient                  Users    @relation("UserAppointments", fields: [userId], references: [id], onDelete: Cascade)
  consultation             Consultations @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([doctorId])
  @@index([consultationId])
}
